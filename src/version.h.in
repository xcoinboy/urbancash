#define STR_HELPER(x) #x
#define STR(x) STR_HELPER(x)

#define PROJECT_NAME "UrbanCash"
#define PROJECT_SITE "https://www.urbancash.org"
#define PROJECT_COPYRIGHT "Copyright 2019-2020, UrbanCash Developers"
#define APP_VER_MAJOR 1
#define APP_VER_MINOR 7
#define APP_VER_REV 0
#define APP_VER_BUILD 888
#define BUILD_COMMIT_ID "@PROJECT_GIT_COMMIT_ID@"
#cmakedefine BUILD_REMARK "@BUILD_REMARK@"
#define PROJECT_VERSION STR(APP_VER_MAJOR) "." STR(APP_VER_MINOR) "." STR(APP_VER_REV)
#define PROJECT_VERSION_BUILD_NO STR(APP_VER_BUILD)

#ifdef BUILD_REMARK
#define PROJECT_VERSION_LONG PROJECT_VERSION "." PROJECT_VERSION_BUILD_NO "-" BUILD_REMARK " (" BUILD_COMMIT_ID ")"
#else
#define PROJECT_VERSION_LONG PROJECT_VERSION "." PROJECT_VERSION_BUILD_NO " (" BUILD_COMMIT_ID ")"
#endif

#define PROJECT_DESCRIPTION PROJECT_NAME " v. " PROJECT_VERSION_LONG
